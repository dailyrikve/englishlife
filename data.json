[
  {"en":"people","syl":"peo·ple","pos":"n.","zh":"人們","ex":"Many people use the post office.","ext":"很多人使用郵局。","tip":"peo 念「批剝」→ 一批一批的人 → 人們(本身就是複數)。"},
  {"en":"time","syl":"time","pos":"n.","zh":"時間","ex":"What time is it now?","ext":"現在幾點?","tip":"諧音「太門」→ 時間是一道太大的門,擋也擋不住。"},
  {"en":"day","syl":"day","pos":"n.","zh":"天;白天","ex":"Today is a busy day.","ext":"今天是忙碌的一天。","tip":"諧音「day(嘟欸)」像太陽出來的一天。"},
  {"en":"year","syl":"year","pos":"n.","zh":"年","ex":"This year is very busy.","ext":"今年非常忙。","tip":"諧音「一耳」→ 過一年長一歲的聯想。"},
  {"en":"week","syl":"week","pos":"n.","zh":"星期;週","ex":"See you next week.","ext":"下週見。","tip":"諧音「微克」→ 一週很短像微小的一克。"},
  {"en":"make","syl":"make","pos":"v.","zh":"製作;使得","ex":"I make breakfast every day.","ext":"我每天做早餐。","tip":"諧音「妹渴」→ 妹妹渴了我來做飲料 → 製作。"},
  {"en":"take","syl":"take","pos":"v.","zh":"拿;帶;花(時間)","ex":"Take this letter with you.","ext":"把這封信帶著。","tip":"和 make 押韻:make 做、take 拿,一做一拿。"},
  {"en":"work","syl":"work","pos":"v./n.","zh":"工作;運作","ex":"The machine does not work.","ext":"這台機器不能運作。","tip":"諧音「我渴」→ 工作到口渴 → work。"},
  {"en":"help","syl":"help","pos":"v./n.","zh":"幫助","ex":"Can you help me?","ext":"你可以幫我嗎?","tip":"求救喊「help!」→ 需要幫助。"},
  {"en":"need","syl":"need","pos":"v.","zh":"需要","ex":"I need your support.","ext":"我需要你的支持。","tip":"諧音「逆的」→ 逆境時最需要幫忙 → 需要。"},
  {"en":"want","syl":"want","pos":"v.","zh":"想要","ex":"I want a cup of tea.","ext":"我想要一杯茶。","tip":"諧音「望」→ 心裡盼望 → 想要。"},
  {"en":"find","syl":"find","pos":"v.","zh":"找到;發現","ex":"I cannot find my keys.","ext":"我找不到我的鑰匙。","tip":"諧音「凡的」→ 凡走過必留痕跡終會找到。"},
  {"en":"give","syl":"give","pos":"v.","zh":"給","ex":"Give me the box, please.","ext":"請把箱子給我。","tip":"短短一個 give 就是「給」,直接記。"},
  {"en":"keep","syl":"keep","pos":"v.","zh":"保持;保留","ex":"Keep the receipt.","ext":"請保留收據。","tip":"諧音「機批」→ 把東西留著 → 保留。"},
  {"en":"learn","syl":"learn","pos":"v.","zh":"學習","ex":"I want to learn English.","ext":"我想學英文。","tip":"learn 裡有 ear(耳朵)→ 用耳朵聽就能學。","syn":[{"en":"study","zh":"研讀"}]},
  {"en":"study","syl":"stu·dy","pos":"v./n.","zh":"研讀;學習","ex":"I study English every day.","ext":"我每天讀英文。","tip":"諧音「死讀」→ 拼命死讀就是 study。","syn":[{"en":"learn","zh":"學習"}]},
  {"en":"start","syl":"start","pos":"v.","zh":"開始","ex":"We start work at nine.","ext":"我們九點開始工作。","tip":"比賽喊「start!」→ 開始。","syn":[{"en":"begin","zh":"開始"}]},
  {"en":"finish","syl":"fin·ish","pos":"v.","zh":"完成;結束","ex":"I finish my work at six.","ext":"我六點完成工作。","tip":"fin(魚鰭)→ 游到終點搖搖鰭 → 結束。","syn":[{"en":"complete","zh":"完成"}]},
  {"en":"change","syl":"change","pos":"v./n.","zh":"改變;零錢","ex":"Please count your change.","ext":"請清點你的零錢。","tip":"換零錢、換一換 → 改變。"},
  {"en":"decide","syl":"de·cide","pos":"v.","zh":"決定","ex":"I cannot decide now.","ext":"我現在無法決定。","tip":"de(去)+cide(切)→ 一刀切下去做決定。"},
  {"en":"enjoy","syl":"en·joy","pos":"v.","zh":"享受;喜愛","ex":"I enjoy my job.","ext":"我喜愛我的工作。","tip":"en(進入)+joy(快樂)→ 進入快樂 → 享受。","syn":[{"en":"like","zh":"喜歡"}]},
  {"en":"feel","syl":"feel","pos":"v.","zh":"感覺","ex":"I feel tired today.","ext":"我今天覺得累。","tip":"諧音「肥喔」→ 摸到肉肉的感覺 → 感覺。"},
  {"en":"become","syl":"be·come","pos":"v.","zh":"變成","ex":"I want to become a teacher.","ext":"我想成為一名老師。","tip":"be+come → 走過來變了樣 → 變成(過去式 became)。"},
  {"en":"bring","syl":"bring","pos":"v.","zh":"帶來","ex":"Bring your ID card.","ext":"帶上你的身分證。","tip":"bring 帶來這裡,take 帶走那裡。"},
  {"en":"carry","syl":"car·ry","pos":"v.","zh":"攜帶;搬運","ex":"I carry two boxes.","ext":"我搬兩個箱子。","tip":"car(車)+ry → 用車搬運 → 攜帶。"},
  {"en":"hold","syl":"hold","pos":"v.","zh":"握住;舉辦","ex":"Hold the door, please.","ext":"請扶住門。","tip":"用手扣住 → 握住(過去式 held)。"},
  {"en":"build","syl":"build","pos":"v.","zh":"建造","ex":"We build a new house.","ext":"我們蓋一棟新房子。","tip":"一塊塊疊起來 → 建造(過去式 built)。"},
  {"en":"buy","syl":"buy","pos":"v.","zh":"買","ex":"I want to buy stamps.","ext":"我想買郵票。","tip":"諧音「拜」→ 拜託老闆賣我 → 買(過去式 bought)。","syn":[{"en":"purchase","zh":"購買"}]},
  {"en":"pay","syl":"pay","pos":"v.","zh":"支付;付錢","ex":"Please pay at the counter.","ext":"請到櫃台付款。","tip":"諧音「配」→ 付了錢才配貨 → 付款(過去式 paid)。"},
  {"en":"sell","syl":"sell","pos":"v.","zh":"賣;販售","ex":"They sell drinks here.","ext":"他們這裡賣飲料。","tip":"sell 賣出、buy 買進(過去式 sold)。"},
  {"en":"send","syl":"send","pos":"v.","zh":"寄送;傳送","ex":"I will send the package today.","ext":"我今天會把包裹寄出。","tip":"諧音「閃的」→ 一閃就寄出 → 寄送(過去式 sent)。","syn":[{"en":"deliver","zh":"遞送"}]},
  {"en":"receive","syl":"re·ceive","pos":"v.","zh":"收到","ex":"Did you receive my email?","ext":"你收到我的信了嗎?","tip":"re(回)+ceive(拿)→ 回手拿進來 → 收到。","syn":[{"en":"get","zh":"得到"}]},
  {"en":"deliver","syl":"de·li·ver","pos":"v.","zh":"遞送;運送","ex":"The mailman will deliver the package tomorrow.","ext":"郵差明天會把包裹送來。","tip":"諧音「的-力-佛」→ 用力把包裹送到 → 遞送。","syn":[{"en":"send","zh":"寄送"}]},
  {"en":"package","syl":"pack·age","pos":"n.","zh":"包裹","ex":"A package arrived this morning.","ext":"今天早上來了一個包裹。","tip":"pack(打包)+age → 打包好的東西 → 包裹。"},
  {"en":"return","syl":"re·turn","pos":"v.","zh":"退回;歸還","ex":"Please return the book.","ext":"請歸還這本書。","tip":"re(再)+turn(轉)→ 再轉回去 → 退回。"},
  {"en":"answer","syl":"an·swer","pos":"v./n.","zh":"回答;答案","ex":"Please answer the question.","ext":"請回答這個問題。","tip":"把答案安上去 → answer(w 不發音)。","syn":[{"en":"reply","zh":"回覆"}]},
  {"en":"ask","syl":"ask","pos":"v.","zh":"詢問;要求","ex":"I want to ask a question.","ext":"我想問一個問題。","tip":"有問題就 ask,張口「阿」一聲問。"},
  {"en":"tell","syl":"tell","pos":"v.","zh":"告訴","ex":"Tell me the truth.","ext":"告訴我真相。","tip":"把話貼到你耳邊 → 告訴(過去式 told)。"},
  {"en":"talk","syl":"talk","pos":"v.","zh":"談話;說話","ex":"We talk every day.","ext":"我們每天聊天。","tip":"你一句我一句 → 談話(l 不發音)。","syn":[{"en":"speak","zh":"說話"}]},
  {"en":"speak","syl":"speak","pos":"v.","zh":"說(語言)","ex":"Can you speak English?","ext":"你會說英文嗎?","tip":"speak 後接語言,強調開口說(過去式 spoke)。","syn":[{"en":"talk","zh":"說話"}]},
  {"en":"read","syl":"read","pos":"v.","zh":"閱讀","ex":"I read the news every day.","ext":"我每天看新聞。","tip":"read 讀書讀到滿腦知識(過去式拼字同 read,念 red)。"},
  {"en":"write","syl":"write","pos":"v.","zh":"書寫","ex":"Write your name here.","ext":"在這裡寫上你的名字。","tip":"w 不發音;right 右手拿筆 write(過去式 wrote)。"},
  {"en":"watch","syl":"watch","pos":"v./n.","zh":"觀看;手錶","ex":"Tom looked at his watch.","ext":"湯姆看了看手錶。","tip":"看時間看 watch(手錶);盯著看也是 watch。"},
  {"en":"show","syl":"show","pos":"v./n.","zh":"展示;表演","ex":"Show me your ticket.","ext":"把你的票給我看。","tip":"諧音「秀」→ 秀出來給人看 → 展示。"},
  {"en":"move","syl":"move","pos":"v.","zh":"移動;搬家","ex":"Please move your car.","ext":"請移動你的車。","tip":"諧音「母舞」→ 跳舞動來動去 → 移動。"},
  {"en":"drive","syl":"drive","pos":"v.","zh":"駕駛;開車","ex":"I drive to work.","ext":"我開車上班。","tip":"抓著方向盤的人 → 駕駛(過去式 drove)。"},
  {"en":"ride","syl":"ride","pos":"v.","zh":"騎乘","ex":"I ride a scooter to work.","ext":"我騎機車上班。","tip":"和 drive 押韻:drive 開四輪,ride 騎兩輪(過去式 rode)。"},
  {"en":"walk","syl":"walk","pos":"v.","zh":"走路","ex":"I walk to the station.","ext":"我走路到車站。","tip":"諧音「我哭」→ 走太遠走到哭(l 不發音)。"},
  {"en":"wait","syl":"wait","pos":"v.","zh":"等待","ex":"Please wait a moment.","ext":"請稍等一下。","tip":"諧音「胃痛」→ 餓著肚子等很久 → 等待。"},
  {"en":"meet","syl":"meet","pos":"v.","zh":"見面;遇見","ex":"Nice to meet you.","ext":"很高興認識你。","tip":"諧音「密特」→ 兩人秘密見面(過去式 met)。"},
  {"en":"join","syl":"join","pos":"v.","zh":"加入;參加","ex":"Join our team!","ext":"加入我們的隊伍!","tip":"諧音「秋因」→ 加入一起玩 → 加入。"},
  {"en":"stay","syl":"stay","pos":"v.","zh":"停留;保持","ex":"Stay here and wait.","ext":"待在這裡等。","tip":"諧音「死貼」→ 死貼著不走 → 停留。"},
  {"en":"leave","syl":"leave","pos":"v.","zh":"離開;留下","ex":"I leave the office at six.","ext":"我六點離開辦公室。","tip":"用力走開 → 離開(過去式 left)。"},
  {"en":"open","syl":"o·pen","pos":"v./adj.","zh":"打開;開著的","ex":"Please open the door.","ext":"請打開門。","tip":"o 像張開的嘴 → 打開。"},
  {"en":"close","syl":"close","pos":"v./adj.","zh":"關閉;接近的","ex":"Please close the door.","ext":"請關門。","tip":"把漏洞闊口關起來 → 關閉。"},
  {"en":"clean","syl":"clean","pos":"v./adj.","zh":"清潔;乾淨的","ex":"I clean the floor every day.","ext":"我每天打掃地板。","tip":"諧音「可寧」→ 打掃乾淨才安寧 → 清潔。"},
  {"en":"wear","syl":"wear","pos":"v.","zh":"穿著;戴著","ex":"Mail carriers wear uniforms.","ext":"郵務士穿著制服。","tip":"ear 耳朵也能 wear 耳環 → 穿戴(過去式 wore)。"},
  {"en":"eat","syl":"eat","pos":"v.","zh":"吃","ex":"Let's eat lunch.","ext":"我們吃午餐吧。","tip":"諧音「一特」→ 一口特好吃 → 吃(過去式 ate)。"},
  {"en":"drink","syl":"drink","pos":"v.","zh":"喝","ex":"I drink water after work.","ext":"我下班後喝水。","tip":"諧音「準客」→ 客人來先喝一杯 → 喝(過去式 drank)。"},
  {"en":"cook","syl":"cook","pos":"v.","zh":"烹煮","ex":"I cook dinner every day.","ext":"我每天煮晚餐。","tip":"大廚 Cook 船長下廚 → 烹煮。"},
  {"en":"sleep","syl":"sleep","pos":"v.","zh":"睡覺","ex":"I sleep eight hours a night.","ext":"我每晚睡八小時。","tip":"累到倒頭就睡(過去式 slept)。"},
  {"en":"rest","syl":"rest","pos":"v./n.","zh":"休息","ex":"Take a rest after work.","ext":"下班後休息一下。","tip":"諧音「累死特」→ 累了要 rest → 休息。"},
  {"en":"win","syl":"win","pos":"v.","zh":"贏;獲勝","ex":"We want to win the game.","ext":"我們想贏得比賽。","tip":"win 就是「贏」(過去式 won)。"},
  {"en":"lose","syl":"lose","pos":"v.","zh":"輸掉;失去","ex":"Do not lose your ticket.","ext":"別弄丟你的票。","tip":"win 的相反;諧音「魯死」→ 輸到很魯(過去式 lost)。"},
  {"en":"try","syl":"try","pos":"v.","zh":"嘗試","ex":"Try your best.","ext":"盡你最大的努力。","tip":"諧音「踹」→ 踹一腳試試 → 嘗試。"},
  {"en":"use","syl":"use","pos":"v./n.","zh":"使用","ex":"Use a pen to sign.","ext":"用筆簽名。","tip":"諧音「優使」→ 好好用 → 使用。"},
  {"en":"check","syl":"check","pos":"v.","zh":"檢查;核對","ex":"Please check the address.","ext":"請核對地址。","tip":"打勾✓就是 check → 檢查。"},
  {"en":"call","syl":"call","pos":"v./n.","zh":"打電話;呼叫","ex":"Call me later.","ext":"晚點打給我。","tip":"諧音「叩」→ 叩叩打電話 → 呼叫。"},
  {"en":"plan","syl":"plan","pos":"v./n.","zh":"計畫","ex":"We made a good plan.","ext":"我們訂了好計畫。","tip":"先計畫好才不會亂 → 計畫。"},
  {"en":"place","syl":"place","pos":"n.","zh":"地方","ex":"This is a quiet place.","ext":"這是個安靜的地方。","tip":"一塊地、一個位子 → 地方。"},
  {"en":"home","syl":"home","pos":"n.","zh":"家","ex":"I go home at six.","ext":"我六點回家。","tip":"溫暖的窩 home → 家。"},
  {"en":"school","syl":"school","pos":"n.","zh":"學校","ex":"The school is near my house.","ext":"學校在我家附近。","tip":"一庫的知識 → 學校。"},
  {"en":"family","syl":"fam·i·ly","pos":"n.","zh":"家庭;家人","ex":"My family is small.","ext":"我家人不多。","tip":"諧音「飯沒理」→ 一家人吃飯 → 家庭。"},
  {"en":"friend","syl":"friend","pos":"n.","zh":"朋友","ex":"She is my best friend.","ext":"她是我最好的朋友。","tip":"friend 藏 end:好朋友到最後都不離。"},
  {"en":"food","syl":"food","pos":"n.","zh":"食物","ex":"The food is delicious.","ext":"食物很美味。","tip":"兩個 o 像兩顆肉丸 → 食物。"},
  {"en":"money","syl":"mon·ey","pos":"n.","zh":"錢","ex":"I have no money today.","ext":"我今天沒錢。","tip":"諧音「媽你」→ 跟媽要錢 → money。"},
  {"en":"car","syl":"car","pos":"n.","zh":"汽車","ex":"The car is very fast.","ext":"這台車很快。","tip":"諧音「卡」→ 車卡在路上 → 汽車。"},
  {"en":"road","syl":"road","pos":"n.","zh":"道路","ex":"This road is busy.","ext":"這條路很繁忙。","tip":"和 route(路線)開頭 ro 一樣 → road 是路。"},
  {"en":"room","syl":"room","pos":"n.","zh":"房間;空間","ex":"The hotel has no room left.","ext":"飯店沒有空房了。","tip":"兩個 o 像兩扇窗 → 房間。"},
  {"en":"job","syl":"job","pos":"n.","zh":"工作;職務","ex":"He found a new job.","ext":"他找到一份新工作。","tip":"job 一份具體的差事;work 較廣泛。","syn":[{"en":"work","zh":"工作"}]},
  {"en":"customer","syl":"cus·to·mer","pos":"n.","zh":"顧客","ex":"The customer needs help.","ext":"這位顧客需要協助。","tip":"custom(習慣)+er → 習慣上門的人 → 顧客。"},
  {"en":"service","syl":"ser·vice","pos":"n.","zh":"服務","ex":"This shop has good service.","ext":"這家店服務很好。","tip":"serve(服務)+ice → 為你服務 → service。"},
  {"en":"office","syl":"of·fice","pos":"n.","zh":"辦公室","ex":"He works in a post office.","ext":"他在郵局工作。","tip":"post office = 郵局,office 就是辦公的地方。"},
  {"en":"counter","syl":"coun·ter","pos":"n.","zh":"櫃台","ex":"Please pay at the counter.","ext":"請到櫃台付款。","tip":"count(數)+er → 在這裡數錢的地方 → 櫃台。"},
  {"en":"support","syl":"sup·port","pos":"n./v.","zh":"支持","ex":"Thank you for your support.","ext":"謝謝你的支持。","tip":"sup(下)+port(搬運)→ 從下面撐住 → 支持。"},
  {"en":"sign","syl":"sign","pos":"v./n.","zh":"簽名;標誌","ex":"Please sign here.","ext":"請在這裡簽名。","tip":"諧音「賽」→ 簽名簽一下(g 不發音)。"},
  {"en":"address","syl":"ad·dress","pos":"n.","zh":"地址","ex":"Write the address clearly.","ext":"把地址寫清楚。","tip":"寄信要 add(加上)dress(衣服位置)→ 地址。"},
  {"en":"weight","syl":"weight","pos":"n.","zh":"重量","ex":"We check the weight of the package.","ext":"我們檢查包裹的重量。","tip":"weigh(秤重)+t → 秤出來的就是 weight 重量(gh 不發音)。"},
  {"en":"fee","syl":"fee","pos":"n.","zh":"費用","ex":"There is a small delivery fee.","ext":"有一筆小額運費。","tip":"諧音「費」→ fee 就是費用。"},
  {"en":"form","syl":"form","pos":"n.","zh":"表格","ex":"Please fill out this form.","ext":"請填寫這份表格。","tip":"諧音「否母」→ 一張要填的格子紙 → 表格。"},
  {"en":"traffic","syl":"traf·fic","pos":"n.","zh":"交通;車流","ex":"The traffic is heavy today.","ext":"今天車流很多。","tip":"諧音「差肥客」→ 路上滿滿的車 → 交通。"},
  {"en":"route","syl":"route","pos":"n.","zh":"路線","ex":"We chose the fastest route.","ext":"我們選了最快的路線。","tip":"開頭 rou 像 road → route 就是路線。"},
  {"en":"avoid","syl":"a·void","pos":"v.","zh":"避免","ex":"We left early to avoid traffic.","ext":"我們提早出發以避開車潮。","tip":"a+void(空的)→ 讓它落空閃開 → 避免。"},
  {"en":"prepare","syl":"pre·pare","pos":"v.","zh":"準備","ex":"I prepare lunch every day.","ext":"我每天準備午餐。","tip":"pre(先)+pare → 事先弄好 → 準備。"},
  {"en":"manage","syl":"man·age","pos":"v.","zh":"設法;管理","ex":"I manage to finish on time.","ext":"我設法準時完成。","tip":"man(人)+age → 帶人做事 → 管理、設法。"},
  {"en":"provide","syl":"pro·vide","pos":"v.","zh":"提供","ex":"We provide free water.","ext":"我們提供免費的水。","tip":"pro(向前)+vide(看)→ 預先看到需求提供 → 提供。","syn":[{"en":"offer","zh":"提供"}]},
  {"en":"offer","syl":"of·fer","pos":"v./n.","zh":"提供;提議","ex":"They offer me a job.","ext":"他們提供我一份工作。","tip":"諧音「歐佛」→ 雙手奉上 → 提供。","syn":[{"en":"provide","zh":"提供"}]},
  {"en":"reduce","syl":"re·duce","pos":"v.","zh":"減少","ex":"We must reduce waste.","ext":"我們必須減少浪費。","tip":"re(回)+duce(引導)→ 往回拉少一點 → 減少。","syn":[{"en":"decrease","zh":"減少"}]},
  {"en":"recycle","syl":"re·cy·cle","pos":"v.","zh":"回收","ex":"Please recycle paper and bottles.","ext":"請回收紙張和瓶子。","tip":"re(再)+cycle(循環)→ 再循環利用 → 回收。"},
  {"en":"protect","syl":"pro·tect","pos":"v.","zh":"保護","ex":"We protect the environment.","ext":"我們保護環境。","tip":"pro(前)+tect(蓋)→ 在前面蓋住擋住 → 保護。"},
  {"en":"prevent","syl":"pre·vent","pos":"v.","zh":"預防;阻止","ex":"Check carefully to prevent mistakes.","ext":"仔細檢查以預防錯誤。","tip":"pre(先)+vent(來)→ 在事情來之前擋下 → 預防。"},
  {"en":"overcome","syl":"o·ver·come","pos":"v.","zh":"克服","ex":"I want to overcome my fear.","ext":"我想克服我的恐懼。","tip":"over(越過)+come(來)→ 跨過困難 → 克服(過去式 overcame)。"},
  {"en":"encourage","syl":"en·cour·age","pos":"v.","zh":"鼓勵","ex":"I encourage you to try.","ext":"我鼓勵你試試看。","tip":"en+courage(勇氣)→ 給你勇氣 → 鼓勵。"},
  {"en":"claim","syl":"claim","pos":"v.","zh":"領取;聲稱","ex":"Please claim your package here.","ext":"請在此領取你的包裹。","tip":"諧音「克雷姆」→ 喊一聲把東西領走 → 領取。"},
  {"en":"purchase","syl":"pur·chase","pos":"v./n.","zh":"購買","ex":"I want to purchase a new bag.","ext":"我想購買一個新包。","tip":"比 buy 正式的「購買」,常見於收據。","syn":[{"en":"buy","zh":"購買"}]},
  {"en":"refund","syl":"re·fund","pos":"n./v.","zh":"退款;退費","ex":"She asked for a refund.","ext":"她要求退款。","tip":"re(再)+fund(資金)→ 把錢再給回去 → 退款。"},
  {"en":"respond","syl":"re·spond","pos":"v.","zh":"回應;回覆","ex":"Please respond to my email.","ext":"請回覆我的電子郵件。","tip":"re(回)+spond(承諾)→ 回話 → 回應(名詞 response)。","syn":[{"en":"reply","zh":"回覆"}]},
  {"en":"suggest","syl":"sug·gest","pos":"v.","zh":"建議","ex":"I suggest you call first.","ext":"我建議你先打電話。","tip":"諧音「色傑斯特」→ 提出一個傑出的點子 → 建議。"},
  {"en":"resign","syl":"re·sign","pos":"v.","zh":"辭職","ex":"He decided to resign.","ext":"他決定辭職。","tip":"re+sign(簽)→ 再簽一張離職單 → 辭職。"},
  {"en":"commute","syl":"com·mute","pos":"v.","zh":"通勤","ex":"I commute to work by MRT.","ext":"我搭捷運通勤上班。","tip":"com(共)+mute → 大家一起來回移動 → 通勤。"},
  {"en":"complain","syl":"com·plain","pos":"v.","zh":"抱怨","ex":"Some people complain about the price.","ext":"有些人抱怨價格。","tip":"com+plain(痛 pain)→ 喊痛 → 抱怨。"},
  {"en":"cancel","syl":"can·cel","pos":"v.","zh":"取消","ex":"I want to cancel my order.","ext":"我想取消我的訂單。","tip":"諧音「砍手」→ 一刀砍掉 → 取消。"},
  {"en":"inform","syl":"in·form","pos":"v.","zh":"通知;告知","ex":"Please inform us of any change.","ext":"如有變動請通知我們。","tip":"in+form(形成)→ 把訊息送進你腦中 → 通知(名詞 information)。"},
  {"en":"receipt","syl":"re·ceipt","pos":"n.","zh":"收據","ex":"Keep your receipt as proof.","ext":"保留收據作為憑證。","tip":"receive(收到)的名詞表親;p 不發音,念「瑞西特」。"},
  {"en":"proof","syl":"proof","pos":"n.","zh":"證明","ex":"You need proof of payment.","ext":"你需要付款證明。","tip":"prove(證明)+f → 證據 → proof。"},
  {"en":"reservation","syl":"res·er·va·tion","pos":"n.","zh":"預約;訂位","ex":"I made a reservation for dinner.","ext":"我訂了晚餐的位子。","tip":"reserve(保留)+ation → 先保留位子 → 預約。"},
  {"en":"experience","syl":"ex·pe·ri·ence","pos":"n.","zh":"經驗","ex":"She has a lot of experience.","ext":"她有很多經驗。","tip":"做過很多次累積下來的 → 經驗。"},
  {"en":"position","syl":"po·si·tion","pos":"n.","zh":"職位","ex":"She applied for the position.","ext":"她應徵了那個職位。","tip":"pose(擺放)→ 你被擺在哪個位子 → 職位。"},
  {"en":"career","syl":"ca·reer","pos":"n.","zh":"職涯;事業","ex":"He had a long career.","ext":"他有很長的職涯。","tip":"諧音「客瑞兒」→ 一輩子的事業 → 職涯。"},
  {"en":"award","syl":"a·ward","pos":"n.","zh":"獎項","ex":"She wants to win the award.","ext":"她想贏得這個獎。","tip":"a+ward(守護)→ 守護你的榮譽 → 獎項。"},
  {"en":"fear","syl":"fear","pos":"n./v.","zh":"恐懼","ex":"Public speaking is a common fear.","ext":"公開演講是常見的恐懼。","tip":"諧音「飛兒」→ 嚇到魂飛 → 恐懼。"},
  {"en":"disaster","syl":"dis·as·ter","pos":"n.","zh":"災難","ex":"The flood was a disaster.","ext":"那場洪水是場災難。","tip":"dis(壞)+aster(星)→ 壞星照命 → 災難。"},
  {"en":"waste","syl":"waste","pos":"n./v.","zh":"浪費;廢棄物","ex":"Do not waste food.","ext":"不要浪費食物。","tip":"諧音「位斯特」→ 丟掉可惜的東西 → 廢棄物、浪費。"},
  {"en":"speech","syl":"speech","pos":"n.","zh":"演講","ex":"He gave a short speech.","ext":"他做了簡短的演講。","tip":"speak(說)的名詞 → 一場演說 → speech。"},
  {"en":"meeting","syl":"meet·ing","pos":"n.","zh":"會議","ex":"The meeting starts at ten.","ext":"會議十點開始。","tip":"meet(見面)+ing → 大家見面開會 → 會議。"},
  {"en":"report","syl":"re·port","pos":"n./v.","zh":"報告","ex":"Please send me the report.","ext":"請把報告寄給我。","tip":"re(回)+port(帶來)→ 把消息帶回來 → 報告。"},
  {"en":"business","syl":"busi·ness","pos":"n.","zh":"商業;生意","ex":"He runs a small business.","ext":"他經營一家小生意。","tip":"busy(忙)+ness → 忙著賺錢的事 → 生意。"},
  {"en":"industry","syl":"in·dus·try","pos":"n.","zh":"產業;工業","ex":"The food industry is growing.","ext":"食品產業正在成長。","tip":"諧音「引得斯吹」→ 一整個行業 → 產業。"},
  {"en":"price","syl":"price","pos":"n.","zh":"價格","ex":"The price is too high.","ext":"價格太高了。","tip":"諧音「不來斯」→ 太貴就不來買 → 價格。"},
  {"en":"amount","syl":"a·mount","pos":"n.","zh":"數量;金額","ex":"Please check the amount.","ext":"請核對金額。","tip":"a+mount(山)→ 堆成一座山的量 → 數量。"},
  {"en":"important","syl":"im·por·tant","pos":"adj.","zh":"重要的","ex":"This is an important letter.","ext":"這是一封重要的信。","tip":"im+port(港口)→ 進出港口的貨很重要 → 重要的。"},
  {"en":"popular","syl":"pop·u·lar","pos":"adj.","zh":"受歡迎的","ex":"The hotel is very popular.","ext":"這家飯店很受歡迎。","tip":"pop(流行)+ular → 大家都愛 → 受歡迎的。"},
  {"en":"famous","syl":"fa·mous","pos":"adj.","zh":"有名的","ex":"She is a famous actress.","ext":"她是位有名的女演員。","tip":"fame(名聲)+ous → 有名聲的 → 有名的。","syn":[{"en":"well-known","zh":"知名的"}]},
  {"en":"possible","syl":"pos·si·ble","pos":"adj.","zh":"可能的","ex":"It is possible to win.","ext":"獲勝是有可能的。","tip":"poss(能)+ible(可以)→ 可能的。"},
  {"en":"impossible","syl":"im·pos·si·ble","pos":"adj.","zh":"不可能的","ex":"It is impossible to finish today.","ext":"今天不可能完成。","tip":"im(不)+possible → 不可能的。"},
  {"en":"difficult","syl":"dif·fi·cult","pos":"adj.","zh":"困難的","ex":"The test was difficult.","ext":"那場考試很難。","tip":"諧音「低糊扣」→ 卡住很難 → 困難的。","syn":[{"en":"hard","zh":"困難的"}]},
  {"en":"easy","syl":"eas·y","pos":"adj.","zh":"容易的","ex":"This question is easy.","ext":"這題很簡單。","tip":"ease(輕鬆)+y → 輕鬆的 → 容易的。","syn":[{"en":"simple","zh":"簡單的"}]},
  {"en":"cheap","syl":"cheap","pos":"adj.","zh":"便宜的","ex":"The drinks here are cheap.","ext":"這裡的飲料很便宜。","tip":"諧音「氣破」→ 便宜到老闆氣破肚 → 便宜的。"},
  {"en":"expensive","syl":"ex·pen·sive","pos":"adj.","zh":"昂貴的","ex":"That phone is too expensive.","ext":"那支手機太貴了。","tip":"ex+pen(花費)→ 花很多錢 → 昂貴的。"},
  {"en":"affordable","syl":"af·ford·a·ble","pos":"adj.","zh":"負擔得起的","ex":"This restaurant is affordable.","ext":"這家餐廳價格實惠。","tip":"afford(負擔)+able → 付得起的 → 實惠的。"},
  {"en":"reliable","syl":"re·li·a·ble","pos":"adj.","zh":"可靠的","ex":"He is a reliable worker.","ext":"他是個可靠的員工。","tip":"rely(依靠)+able → 可以依靠的 → 可靠的。"},
  {"en":"stable","syl":"sta·ble","pos":"adj.","zh":"穩固的;穩定的","ex":"The old house is not stable.","ext":"這棟舊房子不穩固。","tip":"sta(站)+ble → 站得穩 → 穩定的。"},
  {"en":"global","syl":"glo·bal","pos":"adj.","zh":"全球的","ex":"English is a global language.","ext":"英文是全球性的語言。","tip":"globe(地球)+al → 全地球的 → 全球的。"},
  {"en":"delicious","syl":"de·li·cious","pos":"adj.","zh":"美味的","ex":"The meal was delicious.","ext":"那餐很美味。","tip":"諧音「的賴需斯」→ 好吃到賴著不走 → 美味的。","syn":[{"en":"tasty","zh":"美味的"}]},
  {"en":"beautiful","syl":"beau·ti·ful","pos":"adj.","zh":"美麗的","ex":"What a beautiful place!","ext":"多美的地方!","tip":"beauty(美)+ful → 充滿美 → 美麗的。","syn":[{"en":"pretty","zh":"漂亮的"}]},
  {"en":"busy","syl":"bus·y","pos":"adj.","zh":"忙碌的","ex":"He has a busy schedule.","ext":"他的行程很忙。","tip":"諧音「比日」→ 忙到比平日更累 → 忙碌的。"},
  {"en":"ready","syl":"read·y","pos":"adj.","zh":"準備好的","ex":"Are you ready to go?","ext":"你準備好出發了嗎?","tip":"諧音「瑞迪」→ 一切就緒 → 準備好的。"},
  {"en":"safe","syl":"safe","pos":"adj.","zh":"安全的","ex":"Drive safe on rainy days.","ext":"雨天開車要安全。","tip":"諧音「say夫」→ 平安到家說聲安全 → 安全的。"},
  {"en":"careful","syl":"care·ful","pos":"adj.","zh":"小心的","ex":"Be careful with the package.","ext":"小心輕放包裹。","tip":"care(在意)+ful → 充滿在意 → 小心的。"},
  {"en":"careless","syl":"care·less","pos":"adj.","zh":"粗心的","ex":"A careless mistake cost him the job.","ext":"一個粗心的錯誤讓他丟了工作。","tip":"care+less(少)→ 少了在意 → 粗心的。"},
  {"en":"dangerous","syl":"dan·ger·ous","pos":"adj.","zh":"危險的","ex":"Driving in a storm is dangerous.","ext":"暴風雨中開車很危險。","tip":"danger(危險)+ous → 危險的。"},
  {"en":"heavy","syl":"heav·y","pos":"adj.","zh":"重的;大量的","ex":"The box is too heavy.","ext":"這箱子太重了。","tip":"諧音「黑肥」→ 又黑又肥很重 → 重的。"},
  {"en":"quick","syl":"quick","pos":"adj.","zh":"快速的","ex":"We need a quick answer.","ext":"我們需要快速的回覆。","tip":"諧音「虧客」→ 動作快才不虧 → 快速的。","syn":[{"en":"fast","zh":"快速的"}]},
  {"en":"early","syl":"ear·ly","pos":"adv./adj.","zh":"早的;提早","ex":"He arrived early.","ext":"他提早到了。","tip":"ear(耳)+ly → 一大早鳥叫入耳 → 早的。"},
  {"en":"late","syl":"late","pos":"adj./adv.","zh":"遲的;晚的","ex":"Sorry I am late.","ext":"抱歉我遲到了。","tip":"early 的相反;諧音「累的」→ 太累就晚到 → 遲的。"},
  {"en":"free","syl":"free","pos":"adj.","zh":"免費的;自由的","ex":"The hotel offers free drinks.","ext":"飯店提供免費飲料。","tip":"諧音「夫瑞」→ 不用錢、無拘束 → 免費、自由。"},
  {"en":"empty","syl":"emp·ty","pos":"adj.","zh":"空的","ex":"The box is empty.","ext":"這箱子是空的。","tip":"諧音「俺剃」→ 剃光光什麼都沒了 → 空的。"},
  {"en":"quiet","syl":"qui·et","pos":"adj.","zh":"安靜的","ex":"Please keep quiet in the library.","ext":"在圖書館請保持安靜。","tip":"別和 quite(相當)搞混:quiet 多一個 e 在中間 → 安靜。"},
  {"en":"honest","syl":"hon·est","pos":"adj.","zh":"誠實的","ex":"He is an honest man.","ext":"他是個誠實的人。","tip":"h 不發音;心裡 on(開著)→ 坦白 → 誠實的。"},
  {"en":"polite","syl":"po·lite","pos":"adj.","zh":"有禮貌的","ex":"The clerk was very polite.","ext":"那位櫃員很有禮貌。","tip":"諧音「破賴特」→ 不破口、不耍賴 → 有禮貌的。"},
  {"en":"diligent","syl":"dil·i·gent","pos":"adj.","zh":"勤奮的","ex":"She is a diligent student.","ext":"她是個勤奮的學生。","tip":"諧音「弟理近」→ 弟弟天天理書近書 → 勤奮的。"},
  {"en":"lazy","syl":"la·zy","pos":"adj.","zh":"懶惰的","ex":"He is too lazy to study.","ext":"他懶得讀書。","tip":"諧音「累擠」→ 一累就賴床 → 懶惰的。"},
  {"en":"anxious","syl":"anx·ious","pos":"adj.","zh":"焦慮的","ex":"She felt anxious before the test.","ext":"考試前她感到焦慮。","tip":"諧音「骯訐須」→ 心裡七上八下 → 焦慮的。","syn":[{"en":"nervous","zh":"緊張的"}]},
  {"en":"curious","syl":"cu·ri·ous","pos":"adj.","zh":"好奇的","ex":"Children are curious about everything.","ext":"小孩對什麼都好奇。","tip":"諧音「Q裡額斯」→ 一堆問號在腦裡 → 好奇的。"},
  {"en":"similar","syl":"sim·i·lar","pos":"adj.","zh":"相似的","ex":"These two bags look similar.","ext":"這兩個包看起來很像。","tip":"諧音「sém啦」→ same(相同)的親戚 → 相似的。"},
  {"en":"available","syl":"a·vail·a·ble","pos":"adj.","zh":"可獲得的;有空的","ex":"No rooms are available tonight.","ext":"今晚沒有空房。","tip":"avail(有用)+able → 拿得到、有空檔 → 可用的。"},
  {"en":"responsible","syl":"re·spon·si·ble","pos":"adj.","zh":"負責的","ex":"He is responsible for delivery.","ext":"他負責遞送。","tip":"respond(回應)+ible → 能扛起回應的 → 負責的。"},
  {"en":"effective","syl":"ef·fec·tive","pos":"adj.","zh":"有效的","ex":"This is an effective way to learn.","ext":"這是有效的學習方法。","tip":"effect(效果)+ive → 有效果的 → 有效的。"},
  {"en":"public","syl":"pub·lic","pos":"adj.","zh":"公共的;公開的","ex":"He gave a speech in public.","ext":"他在公開場合演講。","tip":"諧音「怕不裡客」→ 大家都進得來 → 公共的。"},
  {"en":"however","syl":"how·ev·er","pos":"adv.","zh":"然而","ex":"It is small; however, it is strong.","ext":"它很小,然而很堅固。","tip":"how+ever → 不管怎樣,話鋒一轉 → 然而。"},
  {"en":"otherwise","syl":"o·ther·wise","pos":"adv.","zh":"否則","ex":"Hurry, otherwise we will be late.","ext":"快點,否則我們會遲到。","tip":"other(其他)+wise → 走另一條路的後果 → 否則。"},
  {"en":"therefore","syl":"there·fore","pos":"adv.","zh":"因此","ex":"It rained; therefore, we stayed home.","ext":"下雨了,因此我們待在家。","tip":"there(那)+fore(前因)→ 因為那緣故 → 因此。"},
  {"en":"meanwhile","syl":"mean·while","pos":"adv.","zh":"同時;與此同時","ex":"I cooked; meanwhile, she cleaned.","ext":"我煮飯,同時她打掃。","tip":"mean+while(當…時)→ 在那當下 → 同時。"},
  {"en":"although","syl":"al·though","pos":"conj.","zh":"雖然","ex":"Although it was late, he kept working.","ext":"雖然很晚了,他仍繼續工作。","tip":"al+though(儘管)→ 雖然。","syn":[{"en":"though","zh":"雖然"}]},
  {"en":"unless","syl":"un·less","pos":"conj.","zh":"除非","ex":"I will not go unless you come.","ext":"除非你來,否則我不去。","tip":"un(不)+less → 不…就不行 → 除非。"},
  {"en":"instead","syl":"in·stead","pos":"adv.","zh":"反而;作為替代","ex":"We took the bus instead.","ext":"我們改搭公車。","tip":"in+stead(位置)→ 站到別的位子 → 取而代之。"},
  {"en":"usually","syl":"u·su·al·ly","pos":"adv.","zh":"通常","ex":"I usually start work at eight.","ext":"我通常八點上班。","tip":"usual(平常)+ly → 平常都這樣 → 通常。","syn":[{"en":"often","zh":"經常"}]},
  {"en":"often","syl":"of·ten","pos":"adv.","zh":"經常","ex":"He is often late.","ext":"他經常遲到。","tip":"諧音「歐分」→ 一分一分常常發生 → 經常(t 可不發音)。","syn":[{"en":"usually","zh":"通常"}]},
  {"en":"already","syl":"al·read·y","pos":"adv.","zh":"已經","ex":"The mail has already arrived.","ext":"郵件已經到了。","tip":"all+ready → 全都好了 → 已經。"},
  {"en":"almost","syl":"al·most","pos":"adv.","zh":"幾乎","ex":"I almost missed the train.","ext":"我差點錯過火車。","tip":"all+most → 幾乎全部 → 幾乎。","syn":[{"en":"nearly","zh":"幾乎"}]},
  {"en":"improve","syl":"im·prove","pos":"v.","zh":"改善;進步","ex":"I want to improve my English.","ext":"我想增進我的英文。","tip":"im+prove(證明)→ 越來越好證明給你看 → 改善。"},
  {"en":"increase","syl":"in·crease","pos":"v.","zh":"增加","ex":"Prices increase every year.","ext":"價格每年上漲。","tip":"in(向內)+crease(長)→ 往上長 → 增加。","syn":[{"en":"rise","zh":"上升"}]},
  {"en":"continue","syl":"con·tin·ue","pos":"v.","zh":"繼續","ex":"We continue to work.","ext":"我們繼續工作。","tip":"con+tinue(拉長)→ 一直拉下去 → 繼續。"},
  {"en":"complete","syl":"com·plete","pos":"v./adj.","zh":"完成;完整的","ex":"Please complete the form.","ext":"請填妥這份表格。","tip":"com+plete(填滿)→ 全填滿 → 完成。","syn":[{"en":"finish","zh":"完成"}]},
  {"en":"attend","syl":"at·tend","pos":"v.","zh":"出席;參加","ex":"He has to attend a meeting.","ext":"他得參加一場會議。","tip":"at+tend(伸向)→ 人到場 → 出席。"},
  {"en":"explain","syl":"ex·plain","pos":"v.","zh":"解釋","ex":"Can you explain the rule?","ext":"你能解釋這規則嗎?","tip":"ex+plain(清楚)→ 講清楚 → 解釋。"},
  {"en":"describe","syl":"de·scribe","pos":"v.","zh":"描述","ex":"Describe the man you saw.","ext":"描述你看到的那個男人。","tip":"de+scribe(寫)→ 用話畫出來 → 描述。"},
  {"en":"compare","syl":"com·pare","pos":"v.","zh":"比較","ex":"Compare the two prices.","ext":"比較這兩個價格。","tip":"com(共)+pare(配對)→ 放一起配對看 → 比較。"},
  {"en":"include","syl":"in·clude","pos":"v.","zh":"包含","ex":"Does the price include tax?","ext":"價格含稅嗎?","tip":"in(內)+clude(關)→ 關在裡面 → 包含。","syn":[{"en":"contain","zh":"包含"}]},
  {"en":"allow","syl":"al·low","pos":"v.","zh":"允許","ex":"We do not allow pets here.","ext":"我們這裡不允許帶寵物。","tip":"諧音「阿撈」→ 點頭讓你撈 → 允許。","syn":[{"en":"permit","zh":"允許"}]},
  {"en":"prefer","syl":"pre·fer","pos":"v.","zh":"比較喜歡","ex":"I prefer tea to coffee.","ext":"比起咖啡我更愛茶。","tip":"pre(先)+fer(拿)→ 先挑的那個 → 偏好。"},
  {"en":"save","syl":"save","pos":"v.","zh":"節省;拯救","ex":"This route can save time.","ext":"這條路線可以省時間。","tip":"諧音「say夫」→ 省下來、救起來 → 節省。"},
  {"en":"spend","syl":"spend","pos":"v.","zh":"花費(錢/時間)","ex":"I spend an hour reading.","ext":"我花一小時閱讀。","tip":"和 send 只差一個 p:把錢「噴」出去 → 花費(過去式 spent)。"},
  {"en":"repair","syl":"re·pair","pos":"v.","zh":"修理","ex":"The machine needs repair.","ext":"這台機器需要修理。","tip":"re(再)+pair(成對)→ 把壞掉的再配好 → 修理。","syn":[{"en":"fix","zh":"修理"}]},
  {"en":"organize","syl":"or·gan·ize","pos":"v.","zh":"組織;籌辦","ex":"We organize a party.","ext":"我們籌辦一場派對。","tip":"organ(器官)+ize → 像身體把各部分安排好 → 組織。"},
